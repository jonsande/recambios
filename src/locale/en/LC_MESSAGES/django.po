msgstr "Categories will appear once products are published and active."

#: src/templates/pages/home.html:77
msgid "Presentación pública inicial del catálogo. Para precio final y plazo siempre se requiere confirmación previa."
msgstr "Initial public catalog presentation. Final price and lead time always require prior confirmation."

#: src/templates/pages/home.html:88
msgid "No hay productos públicos disponibles."
msgstr "No public products are available."

#: src/templates/pages/home.html:89
