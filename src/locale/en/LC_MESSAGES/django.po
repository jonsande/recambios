msgstr "Publish products from the internal panel so they appear here."

#: src/templates/pages/legal.html:4
msgid "Legal | Recambios Técnicos"
msgstr "Legal | Technical Spare Parts"

#: src/templates/pages/legal.html:9
msgid "Aviso legal y condiciones básicas"
msgstr "Legal notice and basic terms"

#: src/templates/pages/legal.html:13
msgid "Información general"
msgstr "General information"

#: src/templates/pages/legal.html:15
msgid "Este sitio muestra información técnica y comercial orientativa sobre recambios. La disponibilidad, el precio final y el plazo de entrega requieren validación previa por el equipo interno."
msgstr "This site shows indicative technical and commercial information about spare parts. Availability, final price, and delivery time require prior validation by the internal team."

#: src/templates/pages/legal.html:20
msgid "Alcance de la información"
msgstr "Scope of information"

#: src/templates/pages/legal.html:22
msgid "Las referencias y descripciones publicadas se revisan de forma continua, pero pueden existir variaciones de proveedor. Se recomienda confirmar cada solicitud antes de formalizar cualquier operación."
msgstr "Published references and descriptions are reviewed continuously, but supplier variations may exist. It is recommended to confirm each request before formalizing any operation."

#: src/templates/pages/legal.html:29
msgid "Para cualquier consulta comercial o legal, utiliza la página de contacto."
msgstr "For any commercial or legal inquiry, use the contact page."
